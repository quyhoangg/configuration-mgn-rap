<core:FragmentDefinition                                                                                                                                                                                                                                       
  xmlns="sap.m"                                                                                                                                                                                                                                                
  xmlns:core="sap.ui.core">                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
  <Popover                                                                                                                                                                                                                                                     
    id="notifPopover"                                                                                                                                                                                                                                          
    placement="Bottom"                                                                                                                                                                                                                                         
    contentWidth="28rem"                                                                                                                                                                                                                                       
    showHeader="false"                                                                                                                                                                                                                                         
    afterClose=".onNotifPopoverClose">                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    <customHeader>                                                                                                                                                                                                                                             
      <Toolbar style="Clear" height="2.75rem">                                                                                                                                                                                                                 
        <Title text="Notifications" level="H5" />                                                                                                                                                                                                              
        <ToolbarSpacer />                                                                                                                                                                                                                                      
        <Button                                                                                                                                                                                                                                                
          text="Mark all read"                                                                                                                                                                                                                                 
          type="Transparent"                                                                                                                                                                                                                                   
          press=".onMarkAllRead"                                                                                                                                                                                                                               
          visible="{= ${notif>/unreadCount} > 0}" />                                                                                                                                                                                                           
        <Button                                                                                                                                                                                                                                                
          icon="sap-icon://delete"                                                                                                                                                                                                                             
          type="Transparent"                                                                                                                                                                                                                                   
          tooltip="Clear all"                                                                                                                                                                                                                                  
          press=".onClearAllNotif" />                                                                                                                                                                                                                          
      </Toolbar>                                                                                                                                                                                                                                               
    </customHeader>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
    <List                                                                                                                                                                                                                                                      
      id="notifList"                                                                                                                                                                                                                                           
      items="{notif>/notifications}"                                                                                                                                                                                                                           
      noDataText="No new notifications"                                                                                                                                                                                                                        
      showSeparators="Inner">                                                                                                                                                                                                                                  
      <CustomListItem                                                                                                                                                                                                                                          
        type="Active"                                                                                                                                                                                                                                          
        press=".onNotifItemPress"                                                                                                                                                                                                                              
        highlight="{= ${notif>read} ? 'None' : 'Information'}"                                                                                                                                                                                                 
        class="confNotifItem">                                                                                                                                                                                                                                 
        <HBox alignItems="Center" class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTopBottom">                                                                                                                                                 
          <core:Icon                                                                                                                                                                                                                                           
            src="{notif>icon}"                                                                                                                                                                                                                                 
            color="{= ${notif>state} === 'Error' ? '#bb0000' : (${notif>state} === 'Success' ? '#107e3e' : (${notif>state} === 'Warning' ? '#e9730c' : '#0070f2'))}"                                                                                           
            size="1.25rem"                                                                                                                                                                                                                                     
            class="sapUiSmallMarginEnd" />                                                                                                                                                                                                                     
          <VBox class="confNotifText" fitContainer="true">                                                                                                                                                                                                     
            <Text                                                                                                                                                                                                                                              
              text="{notif>title}"                                                                                                                                                                                                                             
              maxLines="1"                                                                                                                                                                                                                                     
              class="confNotifTitle" />                                                                                                                                                                                                                        
            <Text                                                                                                                                                                                                                                              
              text="{notif>message}"                                                                                                                                                                                                                           
              maxLines="2"                                                                                                                                                                                                                                     
              wrapping="true"                                                                                                                                                                                                                                  
              class="confNotifMessage" />                                                                                                                                                                                                                      
          </VBox>                                                                                                                                                                                                                                              
          <VBox class="confNotifMeta" justifyContent="Center">                                                                                                                                                                                                 
            <Text                                                                                                                                                                                                                                              
              text="{notif>time}"                                                                                                                                                                                                                              
              textAlign="End"                                                                                                                                                                                                                                  
              class="confNotifTime" />                                                                                                                                                                                                                         
          </VBox>                                                                                                                                                                                                                                              
        </HBox>                                                                                                                                                                                                                                                
      </CustomListItem>                                                                                                                                                                                                                                        
    </List>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
  </Popover>                                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               