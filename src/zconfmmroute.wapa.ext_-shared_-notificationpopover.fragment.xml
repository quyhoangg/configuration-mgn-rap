<core:FragmentDefinition                                                                                                                                                                                                                                       
  xmlns="sap.m"                                                                                                                                                                                                                                                
  xmlns:core="sap.ui.core">                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
  <Popover                                                                                                                                                                                                                                                     
    id="notifPopover"                                                                                                                                                                                                                                          
    title="Notifications"                                                                                                                                                                                                                                      
    placement="Bottom"                                                                                                                                                                                                                                         
    contentWidth="22rem"                                                                                                                                                                                                                                       
    afterClose=".onNotifPopoverClose">                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    <customHeader>                                                                                                                                                                                                                                             
      <Toolbar style="background:transparent;">                                                                                                                                                                                                                
        <Title text="Notifications" level="H5" />                                                                                                                                                                                                              
        <ToolbarSpacer />                                                                                                                                                                                                                                      
        <Button                                                                                                                                                                                                                                                
          text="Mark all read"                                                                                                                                                                                                                                 
          type="Transparent"                                                                                                                                                                                                                                   
          press=".onMarkAllRead"                                                                                                                                                                                                                               
          visible="{= ${notif>/unreadCount} > 0}" />                                                                                                                                                                                                           
        <Button                                                                                                                                                                                                                                                
          icon="sap-icon://delete"                                                                                                                                                                                                                             
          type="Transparent"                                                                                                                                                                                                                                   
          tooltip="Clear all"                                                                                                                                                                                                                                  
          press=".onClearAllNotif" />                                                                                                                                                                                                                          
      </Toolbar>                                                                                                                                                                                                                                               
    </customHeader>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
    <List                                                                                                                                                                                                                                                      
      id="notifList"                                                                                                                                                                                                                                           
      items="{notif>/notifications}"                                                                                                                                                                                                                           
      noDataText="No notifications"                                                                                                                                                                                                                            
      showSeparators="Inner">                                                                                                                                                                                                                                  
      <StandardListItem                                                                                                                                                                                                                                        
        title="{notif>title}"                                                                                                                                                                                                                                  
        description="{notif>message}"                                                                                                                                                                                                                          
        info="{notif>time}"                                                                                                                                                                                                                                    
        infoState="{notif>state}"                                                                                                                                                                                                                              
        icon="{notif>icon}"                                                                                                                                                                                                                                    
        iconDensityAware="false"                                                                                                                                                                                                                               
        type="Active"                                                                                                                                                                                                                                          
        press=".onNotifItemPress"                                                                                                                                                                                                                              
        highlight="{= ${notif>read} ? 'None' : 'Information'}" />                                                                                                                                                                                              
    </List>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
  </Popover>                                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               