sap.ui.define(                                                                                                                                                                                                                                                 
  [                                                                                                                                                                                                                                                            
    "sap/ui/core/mvc/ControllerExtension",                                                                                                                                                                                                                     
    "sap/ui/core/Component",                                                                                                                                                                                                                                   
    "sap/m/VBox",                                                                                                                                                                                                                                              
    "sap/m/HBox",                                                                                                                                                                                                                                              
    "sap/m/Text",                                                                                                                                                                                                                                              
    "sap/ui/core/Icon",                                                                                                                                                                                                                                        
    "sap/m/MessageStrip",                                                                                                                                                                                                                                      
    "sap/uxap/ObjectPageSection",                                                                                                                                                                                                                              
    "sap/uxap/ObjectPageSubSection",                                                                                                                                                                                                                           
  ],                                                                                                                                                                                                                                                           
  function (                                                                                                                                                                                                                                                   
    ControllerExtension,                                                                                                                                                                                                                                       
    Component,                                                                                                                                                                                                                                                 
    VBox,                                                                                                                                                                                                                                                      
    HBox,                                                                                                                                                                                                                                                      
    Text,                                                                                                                                                                                                                                                      
    Icon,                                                                                                                                                                                                                                                      
    MessageStrip,                                                                                                                                                                                                                                              
    ObjectPageSection,                                                                                                                                                                                                                                         
    ObjectPageSubSection                                                                                                                                                                                                                                       
  ) {                                                                                                                                                                                                                                                          
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    var _aStatusOrder = ["DRAFT", "SUBMITTED", "APPROVED", "PROMOTED"];                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
    var _mLabel = {                                                                                                                                                                                                                                            
      DRAFT:     "Draft",                                                                                                                                                                                                                                      
      SUBMITTED: "Submitted",                                                                                                                                                                                                                                  
      APPROVED:  "Approved",                                                                                                                                                                                                                                   
      PROMOTED:  "Promoted",                                                                                                                                                                                                                                   
      REJECTED:  "Rejected",                                                                                                                                                                                                                                   
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    // ── CSS injected once into <head> ──────────────────────────────────────────                                                                                                                                                                             
    var CSS = [                                                                                                                                                                                                                                                
      ".csMngStepper{display:flex;align-items:flex-start;width:100%;padding:12px 0}",                                                                                                                                                                          
      ".csMngStep{display:flex;flex-direction:column;align-items:center;min-width:80px}",                                                                                                                                                                      
      ".csMngLine{flex:1;height:0;border-top:2px solid #c0c4c9;margin-top:18px;min-width:24px;align-self:flex-start}",                                                                                                                                         
      ".csMngLine.done{border-color:#107e3e}",                                                                                                                                                                                                                 
      ".csMngCircle{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center}",                                                                                                                                         
      ".csMngCircle.done{background:#107e3e}",                                                                                                                                                                                                                 
      ".csMngCircle.current{background:#0070f2}",                                                                                                                                                                                                              
      ".csMngCircle.rejected{background:#bb0000}",                                                                                                                                                                                                             
      ".csMngCircle.future{background:#89919a}",                                                                                                                                                                                                               
      ".csMngLabel{font-size:.8rem;font-weight:600;margin-top:6px;color:#32363a;text-align:center}",                                                                                                                                                           
      ".csMngLabel.current{color:#0070f2}",                                                                                                                                                                                                                    
      ".csMngLabel.done{color:#107e3e}",                                                                                                                                                                                                                       
      ".csMngLabel.rejected{color:#bb0000}",                                                                                                                                                                                                                   
      ".csMngSub{font-size:.7rem;color:#6a6d70;text-align:center;white-space:pre-line;margin-top:2px}",                                                                                                                                                        
    ].join("");                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
    function _injectCSS() {                                                                                                                                                                                                                                    
      if (!document.getElementById("csMngStepCSS")) {                                                                                                                                                                                                          
        var el = document.createElement("style");                                                                                                                                                                                                              
        el.id = "csMngStepCSS";                                                                                                                                                                                                                                
        el.textContent = CSS;                                                                                                                                                                                                                                  
        document.head.appendChild(el);                                                                                                                                                                                                                         
      }                                                                                                                                                                                                                                                        
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    function _fmt(vDate) {                                                                                                                                                                                                                                     
      if (!vDate) { return ""; }                                                                                                                                                                                                                               
      try {                                                                                                                                                                                                                                                    
        var d = vDate instanceof Date ? vDate : new Date(vDate);                                                                                                                                                                                               
        if (isNaN(d.getTime())) { return ""; }                                                                                                                                                                                                                 
        return d.toLocaleDateString(undefined, { day: "2-digit", month: "short", year: "numeric" });                                                                                                                                                           
      } catch (e) { return ""; }                                                                                                                                                                                                                               
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    return ControllerExtension.extend(                                                                                                                                                                                                                         
      "zgsp26.conf.request.confrequestapp.ext.controller.RequestObjectExt",                                                                                                                                                                                    
      {                                                                                                                                                                                                                                                        
        override: {                                                                                                                                                                                                                                            
          onAfterRendering: function () {                                                                                                                                                                                                                      
            // Attach a persistent modelContextChange listener once so that                                                                                                                                                                                    
            // navigating between requests (2nd, 3rd …) always re-renders the                                                                                                                                                                                  
            // status section with the new binding context.                                                                                                                                                                                                    
            if (!this._bContextListenerAttached) {                                                                                                                                                                                                             
              this._bContextListenerAttached = true;                                                                                                                                                                                                           
              this.base.getView().attachEvent("modelContextChange", function () {                                                                                                                                                                              
                var oCtx = this.base.getView().getBindingContext();                                                                                                                                                                                            
                if (oCtx) { this._renderStatusSection(oCtx); }                                                                                                                                                                                                 
              }.bind(this));                                                                                                                                                                                                                                   
            }                                                                                                                                                                                                                                                  
            this._tryRenderStatusSection();                                                                                                                                                                                                                    
          },                                                                                                                                                                                                                                                   
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        // ─── Status Section ────────────────────────────────────────────────────                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        _tryRenderStatusSection: function () {                                                                                                                                                                                                                 
          var oView    = this.base.getView();                                                                                                                                                                                                                  
          var oContext = oView.getBindingContext();                                                                                                                                                                                                            
          if (oContext) {                                                                                                                                                                                                                                      
            this._renderStatusSection(oContext);                                                                                                                                                                                                               
          }                                                                                                                                                                                                                                                    
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        _renderStatusSection: function (oContext) {                                                                                                                                                                                                            
          var that = this;                                                                                                                                                                                                                                     
          oContext.requestProperty([                                                                                                                                                                                                                           
            "Status", "RejectReason", "RejectedBy", "ApprovedBy",                                                                                                                                                                                              
            "CreatedBy", "CreatedAt", "ApprovedAt", "RejectedAt",                                                                                                                                                                                              
          ]).then(function (aVals) {                                                                                                                                                                                                                           
            that._buildStatusSection({                                                                                                                                                                                                                         
              status:       aVals[0] || "DRAFT",                                                                                                                                                                                                               
              rejectReason: aVals[1] || "",                                                                                                                                                                                                                    
              rejectedBy:   aVals[2] || "",                                                                                                                                                                                                                    
              approvedBy:   aVals[3] || "",                                                                                                                                                                                                                    
              createdBy:    aVals[4] || "",                                                                                                                                                                                                                    
              createdAt:    aVals[5] || null,                                                                                                                                                                                                                  
              approvedAt:   aVals[6] || null,                                                                                                                                                                                                                  
              rejectedAt:   aVals[7] || null,                                                                                                                                                                                                                  
            });                                                                                                                                                                                                                                                
          }).catch(function (err) {                                                                                                                                                                                                                            
            console.warn("[StatusSection] requestProperty failed:", err);                                                                                                                                                                                      
          });                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        _buildStatusSection: function (o) {                                                                                                                                                                                                                    
          _injectCSS();                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
          var oView   = this.base.getView();                                                                                                                                                                                                                   
          var oLayout = this._findObjectPageLayout();                                                                                                                                                                                                          
          if (!oLayout) { return; }                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
          var oExisting = oView.byId("statusProgressSection");                                                                                                                                                                                                 
          if (oExisting) { oLayout.removeSection(oExisting); oExisting.destroy(); }                                                                                                                                                                            
                                                                                                                                                                                                                                                               
          var bRejected = (o.status === "REJECTED");                                                                                                                                                                                                           
          var aBlockItems = [];                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
          // ── Alert strip ─────────────────────────────────────────────────────                                                                                                                                                                              
          if (bRejected) {                                                                                                                                                                                                                                     
            aBlockItems.push(new MessageStrip({                                                                                                                                                                                                                
              text: "Rejected" + (o.rejectedBy ? " by " + o.rejectedBy : "")                                                                                                                                                                                   
                + (o.rejectReason ? ': "' + o.rejectReason + '"' : "."),                                                                                                                                                                                       
              type: "Error",                                                                                                                                                                                                                                   
              showIcon: true,                                                                                                                                                                                                                                  
            }).addStyleClass("sapUiSmallMarginBottom"));                                                                                                                                                                                                       
          } else if (o.status === "APPROVED" && o.approvedBy) {                                                                                                                                                                                                
            aBlockItems.push(new MessageStrip({                                                                                                                                                                                                                
              text: "Approved by " + o.approvedBy + ". Ready to be promoted.",                                                                                                                                                                                 
              type: "Success",                                                                                                                                                                                                                                 
              showIcon: true,                                                                                                                                                                                                                                  
            }).addStyleClass("sapUiSmallMarginBottom"));                                                                                                                                                                                                       
          } else if (o.status === "PROMOTED") {                                                                                                                                                                                                                
            aBlockItems.push(new MessageStrip({                                                                                                                                                                                                                
              text: "Configuration has been successfully promoted to all target environments.",                                                                                                                                                                
              type: "Success",                                                                                                                                                                                                                                 
              showIcon: true,                                                                                                                                                                                                                                  
            }).addStyleClass("sapUiSmallMarginBottom"));                                                                                                                                                                                                       
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          // ── Step config ──────────────────────────────────────────────────────                                                                                                                                                                             
          var aSteps    = bRejected ? ["DRAFT", "SUBMITTED", "REJECTED"] : ["DRAFT", "SUBMITTED", "APPROVED", "PROMOTED"];                                                                                                                                     
          var iCurrent  = bRejected ? 2 : _aStatusOrder.indexOf(o.status);                                                                                                                                                                                     
          var bAllDone  = (o.status === "PROMOTED");                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
          var mSub = {                                                                                                                                                                                                                                         
            DRAFT:     (o.createdBy  ? "by " + o.createdBy  : "") + (_fmt(o.createdAt)  ? "\n" + _fmt(o.createdAt)  : ""),                                                                                                                                     
            SUBMITTED: "",                                                                                                                                                                                                                                     
            APPROVED:  (o.approvedBy ? "by " + o.approvedBy : "") + (_fmt(o.approvedAt) ? "\n" + _fmt(o.approvedAt) : ""),                                                                                                                                     
            REJECTED:  (o.rejectedBy ? "by " + o.rejectedBy : "") + (_fmt(o.rejectedAt) ? "\n" + _fmt(o.rejectedAt) : ""),                                                                                                                                     
            PROMOTED:  "",                                                                                                                                                                                                                                     
          };                                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
          var mIcon = {                                                                                                                                                                                                                                        
            done:     "sap-icon://accept",                                                                                                                                                                                                                     
            current:  "sap-icon://sys-enter-2",                                                                                                                                                                                                                
            rejected: "sap-icon://error",                                                                                                                                                                                                                      
            future:   "sap-icon://circle-task-2",                                                                                                                                                                                                              
          };                                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
          var mIconColor = {                                                                                                                                                                                                                                   
            done: "#ffffff", current: "#ffffff", rejected: "#ffffff", future: "#ffffff",                                                                                                                                                                       
          };                                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
          // ── Build HBox items ─────────────────────────────────────────────────                                                                                                                                                                             
          var aHBoxItems = [];                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
          aSteps.forEach(function (sStep, i) {                                                                                                                                                                                                                 
            var sState;                                                                                                                                                                                                                                        
            if (bRejected)        { sState = (i === 2) ? "rejected" : "done"; }                                                                                                                                                                                
            else if (bAllDone)    { sState = "done"; }                                                                                                                                                                                                         
            else if (i < iCurrent)  { sState = "done"; }                                                                                                                                                                                                       
            else if (i === iCurrent) { sState = "current"; }                                                                                                                                                                                                   
            else                  { sState = "future"; }                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            // Circle with icon — rendered as a native div via addStyleClass trick:                                                                                                                                                                            
            // We wrap an Icon in a VBox and apply circle styles via DOM after render.                                                                                                                                                                         
            var oIcon = new Icon({                                                                                                                                                                                                                             
              src:   mIcon[sState],                                                                                                                                                                                                                            
              color: mIconColor[sState],                                                                                                                                                                                                                       
              size:  "1rem",                                                                                                                                                                                                                                   
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            // Circle container — use a VBox + custom class, inject color via style attr                                                                                                                                                                       
            var oCircleBox = new VBox({                                                                                                                                                                                                                        
              alignItems: "Center",                                                                                                                                                                                                                            
              justifyContent: "Center",                                                                                                                                                                                                                        
              items: [oIcon],                                                                                                                                                                                                                                  
            }).addStyleClass("csMngCircle " + sState);                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            // Label                                                                                                                                                                                                                                           
            var oLabel = new Text({                                                                                                                                                                                                                            
              text: _mLabel[sStep] || sStep,                                                                                                                                                                                                                   
              wrapping: false,                                                                                                                                                                                                                                 
            }).addStyleClass("csMngLabel " + (sState === "future" ? "" : sState));                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            var oStepVBox = new VBox({                                                                                                                                                                                                                         
              alignItems: "Center",                                                                                                                                                                                                                            
              items: [oCircleBox, oLabel],                                                                                                                                                                                                                     
            }).addStyleClass("csMngStep");                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
            // Sub-text (who/when)                                                                                                                                                                                                                             
            var sSub = mSub[sStep] || "";                                                                                                                                                                                                                      
            if (sSub.trim()) {                                                                                                                                                                                                                                 
              oStepVBox.addItem(                                                                                                                                                                                                                               
                new Text({ text: sSub.trim(), wrapping: true }).addStyleClass("csMngSub")                                                                                                                                                                      
              );                                                                                                                                                                                                                                               
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            aHBoxItems.push(oStepVBox);                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            // Connector line between steps                                                                                                                                                                                                                    
            if (i < aSteps.length - 1) {                                                                                                                                                                                                                       
              var oLine = new VBox({}).addStyleClass("csMngLine" + (sState === "done" ? " done" : ""));                                                                                                                                                        
              aHBoxItems.push(oLine);                                                                                                                                                                                                                          
            }                                                                                                                                                                                                                                                  
          });                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
          var oStepper = new HBox({                                                                                                                                                                                                                            
            items: aHBoxItems,                                                                                                                                                                                                                                 
          }).addStyleClass("csMngStepper");                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          aBlockItems.push(oStepper);                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
          // ── Assemble section ──────────────────────────────────────────────────                                                                                                                                                                            
          var oSection = new ObjectPageSection(                                                                                                                                                                                                                
            oView.createId("statusProgressSection"),                                                                                                                                                                                                           
            {                                                                                                                                                                                                                                                  
              title: "Request Progress",                                                                                                                                                                                                                       
              subSections: [                                                                                                                                                                                                                                   
                new ObjectPageSubSection({                                                                                                                                                                                                                     
                  blocks: [new VBox({ items: aBlockItems })],                                                                                                                                                                                                  
                }),                                                                                                                                                                                                                                            
              ],                                                                                                                                                                                                                                               
            }                                                                                                                                                                                                                                                  
          );                                                                                                                                                                                                                                                   
          oSection.data("renderedStatus", o.status);                                                                                                                                                                                                           
          oLayout.insertSection(oSection, 0);                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        // ─── Helpers ──────────────────────────────────────────────────────────                                                                                                                                                                              
                                                                                                                                                                                                                                                               
        _findObjectPageLayout: function () {                                                                                                                                                                                                                   
          var oView = this.base.getView();                                                                                                                                                                                                                     
          var aLayouts = oView.findAggregatedObjects(true, function (oCtrl) {                                                                                                                                                                                  
            return oCtrl.isA && oCtrl.isA("sap.uxap.ObjectPageLayout");                                                                                                                                                                                        
          });                                                                                                                                                                                                                                                  
          return aLayouts && aLayouts.length ? aLayouts[0] : null;                                                                                                                                                                                             
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        _getAppComponent: function () {                                                                                                                                                                                                                        
          var oView = this.base.getView();                                                                                                                                                                                                                     
          return this.base.getAppComponent                                                                                                                                                                                                                     
            ? this.base.getAppComponent()                                                                                                                                                                                                                      
            : Component.getOwnerComponentFor(oView);                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        // ─── Open Config Action ───────────────────────────────────────────────                                                                                                                                                                              
                                                                                                                                                                                                                                                               
        _getUrlParams: function () {                                                                                                                                                                                                                           
          var oParams = new URLSearchParams(window.location.search);                                                                                                                                                                                           
          return {                                                                                                                                                                                                                                             
            ConfId:    oParams.get("ConfId")    || "",                                                                                                                                                                                                         
            ConfName:  oParams.get("ConfName")  || "",                                                                                                                                                                                                         
            ModuleId:  oParams.get("ModuleId")  || "",                                                                                                                                                                                                         
            TargetCds: oParams.get("TargetCds") || "",                                                                                                                                                                                                         
          };                                                                                                                                                                                                                                                   
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        _getConfigAppUrl: function (sTargetCds) {                                                                                                                                                                                                              
          var APP_PATH_MAP = {                                                                                                                                                                                                                                 
            ZI_MM_ROUTE_CONF: { local: "http://localhost:8082/index.html", deploy: "/sap/bc/ui5_ui5/sap/zconfmmroute/index.html" },                                                                                                                            
            ZI_SD_PRICE_CONF: { local: "http://localhost:8083/index.html", deploy: "/sap/bc/ui5_ui5/sap/zconfsdprice/index.html" },                                                                                                                            
            ZI_FI_LIMIT_CONF: { local: "http://localhost:8084/index.html", deploy: "/sap/bc/ui5_ui5/sap/zconffillimit/index.html" },                                                                                                                           
            ZI_MM_SAFE_STOCK: { local: "http://localhost:8085/index.html", deploy: "/sap/bc/ui5_ui5/sap/zui_mm_safestk/index.html" },                                                                                                                          
          };                                                                                                                                                                                                                                                   
          var sMode  = localStorage.getItem("conf-mng-nav-mode") ||                                                                                                                                                                                            
            (window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1"                                                                                                                                                              
              ? "local" : "deploy");                                                                                                                                                                                                                           
          var oEntry = APP_PATH_MAP[sTargetCds] || APP_PATH_MAP["ZI_MM_ROUTE_CONF"];                                                                                                                                                                           
          var sPath  = oEntry[sMode] || oEntry.deploy;                                                                                                                                                                                                         
          return sMode === "deploy" ? window.location.origin + sPath : sPath;                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        onOpenConfig: async function () {                                                                                                                                                                                                                      
          try {                                                                                                                                                                                                                                                
            var oView    = this.base.getView();                                                                                                                                                                                                                
            var oContext = oView.getBindingContext();                                                                                                                                                                                                          
            if (!oContext) { return; }                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            var oData      = oContext.getObject();                                                                                                                                                                                                             
            var oUrlParams = this._getUrlParams();                                                                                                                                                                                                             
            var sReqId     = oData.ReqId    || "";                                                                                                                                                                                                             
            var sConfId    = oData.ConfId   || oUrlParams.ConfId   || "";                                                                                                                                                                                      
            var sConfName  = oData.ConfName || oUrlParams.ConfName || "";                                                                                                                                                                                      
            var sModuleId  = oData.ModuleId || oUrlParams.ModuleId || "";                                                                                                                                                                                      
            var sStatus    = oData.Status   || "D";                                                                                                                                                                                                            
            var sEnvId     = oData.EnvId    || "DEV";                                                                                                                                                                                                          
            var sTargetCds = oData.TargetCds || oUrlParams.TargetCds || "";                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            if (!sReqId) { return; }                                                                                                                                                                                                                           
            if (!sTargetCds) {                                                                                                                                                                                                                                 
              sap.m.MessageBox.error("TargetCds is missing — cannot determine config app");                                                                                                                                                                    
              return;                                                                                                                                                                                                                                          
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var sUrl = this._getConfigAppUrl(sTargetCds)                                                                                                                                                                                                       
              + "?sap-client=" + (new URLSearchParams(window.location.search).get("sap-client") || "324")                                                                                                                                                      
              + "&ReqId="     + encodeURIComponent(sReqId)                                                                                                                                                                                                     
              + "&ConfId="    + encodeURIComponent(sConfId)                                                                                                                                                                                                    
              + "&ConfName="  + encodeURIComponent(sConfName)                                                                                                                                                                                                  
              + "&ModuleId="  + encodeURIComponent(sModuleId)                                                                                                                                                                                                  
              + "&TargetCds=" + encodeURIComponent(sTargetCds)                                                                                                                                                                                                 
              + "&EnvId="     + encodeURIComponent(sEnvId)                                                                                                                                                                                                     
              + "&Status="    + encodeURIComponent(sStatus);                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            var oLink = document.createElement("a");                                                                                                                                                                                                           
            oLink.href = sUrl; oLink.target = "_self"; oLink.rel = "noopener noreferrer";                                                                                                                                                                      
            document.body.appendChild(oLink);                                                                                                                                                                                                                  
            oLink.click();                                                                                                                                                                                                                                     
            document.body.removeChild(oLink);                                                                                                                                                                                                                  
          } catch (e) {                                                                                                                                                                                                                                        
            console.error("onOpenConfig error:", e);                                                                                                                                                                                                           
          }                                                                                                                                                                                                                                                    
        },                                                                                                                                                                                                                                                     
      }                                                                                                                                                                                                                                                        
    );                                                                                                                                                                                                                                                         
  }                                                                                                                                                                                                                                                            
);                                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               