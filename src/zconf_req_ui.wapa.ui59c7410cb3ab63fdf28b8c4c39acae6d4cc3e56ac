sap.ui.define(                                                                                                                                                                                                                                                 
  ["sap/m/MessageBox", "sap/ui/core/BusyIndicator"],                                                                                                                                                                                                           
  function (MessageBox, BusyIndicator) {                                                                                                                                                                                                                       
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    function _getSapClient() {                                                                                                                                                                                                                                 
      return (                                                                                                                                                                                                                                                 
        new URLSearchParams(window.location.search).get("sap-client") || "324"                                                                                                                                                                                 
      );                                                                                                                                                                                                                                                       
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    var APP_PATH_MAP = {                                                                                                                                                                                                                                       
      ZI_MM_ROUTE_CONF: { local: "http://localhost:8082/index.html", deploy: "/sap/bc/ui5_ui5/sap/zconfmmroute/index.html" },                                                                                                                                  
      ZI_SD_PRICE_CONF: { local: "http://localhost:8083/index.html", deploy: "/sap/bc/ui5_ui5/sap/zconfsdprice/index.html" },                                                                                                                                  
      ZI_FI_LIMIT_CONF: { local: "http://localhost:8084/index.html", deploy: "/sap/bc/ui5_ui5/sap/zconffillimit/index.html" },                                                                                                                                 
      ZI_MM_SAFE_STOCK: { local: "http://localhost:8085/index.html", deploy: "/sap/bc/ui5_ui5/sap/zui_mm_safestk/index.html" },                                                                                                                                
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    // Nav mode: auto-detect by hostname; override via: localStorage.setItem("conf-mng-nav-mode", "local"/"deploy")                                                                                                                                            
    function _getConfigAppUrl(sTargetCds) {                                                                                                                                                                                                                    
      var sMode = localStorage.getItem("conf-mng-nav-mode") ||                                                                                                                                                                                                 
        (window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1"                                                                                                                                                                  
          ? "local" : "deploy");                                                                                                                                                                                                                               
      var oEntry = APP_PATH_MAP[sTargetCds] || APP_PATH_MAP["ZI_MM_ROUTE_CONF"];                                                                                                                                                                               
      var sPath = oEntry[sMode] || oEntry.deploy;                                                                                                                                                                                                              
      return sMode === "deploy" ? window.location.origin + sPath : sPath;                                                                                                                                                                                      
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    return {                                                                                                                                                                                                                                                   
      onOpenConfig: async function (oContext) {                                                                                                                                                                                                                
        try {                                                                                                                                                                                                                                                  
          // Resolve binding context                                                                                                                                                                                                                           
          let oBindingContext = null;                                                                                                                                                                                                                          
          if (oContext && typeof oContext.requestObject === "function") {                                                                                                                                                                                      
            oBindingContext = oContext;                                                                                                                                                                                                                        
          } else if (Array.isArray(oContext) && oContext[0]) {                                                                                                                                                                                                 
            oBindingContext = oContext[0];                                                                                                                                                                                                                     
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          if (!oBindingContext) {                                                                                                                                                                                                                              
            MessageBox.error("No binding context found");                                                                                                                                                                                                      
            return;                                                                                                                                                                                                                                            
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          BusyIndicator.show(0);                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
          const oData = await oBindingContext.requestObject();                                                                                                                                                                                                 
          console.log("OpenConfigAction oData:", JSON.stringify(oData));                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
          // TargetCds is a JOIN field — Fiori Elements object page may not load it.                                                                                                                                                                           
          // Fallback order: entity data → URL search params (always present when                                                                                                                                                                              
          // navigating from Catalog/CatalogLanding)                                                                                                                                                                                                           
          var oUrlParams = new URLSearchParams(window.location.search);                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
          const sReqId     = oData.ReqId    || "";                                                                                                                                                                                                             
          const sConfId    = oData.ConfId   || oUrlParams.get("ConfId")   || "";                                                                                                                                                                               
          const sConfName  = oData.ConfName || oUrlParams.get("ConfName") || oData.ReqTitle || "";                                                                                                                                                             
          const sModuleId  = oData.ModuleId || oUrlParams.get("ModuleId") || "";                                                                                                                                                                               
          const sStatus    = oData.Status   || "D";                                                                                                                                                                                                            
          const sEnvId     = oData.EnvId    || oUrlParams.get("EnvId")    || "DEV";                                                                                                                                                                            
          const sTargetCds = oData.TargetCds || oUrlParams.get("TargetCds") || "";                                                                                                                                                                             
                                                                                                                                                                                                                                                               
          if (!sReqId) {                                                                                                                                                                                                                                       
            BusyIndicator.hide();                                                                                                                                                                                                                              
            MessageBox.error("ReqId is missing");                                                                                                                                                                                                              
            return;                                                                                                                                                                                                                                            
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          if (!sTargetCds) {                                                                                                                                                                                                                                   
            BusyIndicator.hide();                                                                                                                                                                                                                              
            MessageBox.error("TargetCds is missing — cannot determine config app");                                                                                                                                                                            
            return;                                                                                                                                                                                                                                            
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          const sAppPath = _getConfigAppUrl(sTargetCds);                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
          const sUrl =                                                                                                                                                                                                                                         
            sAppPath +                                                                                                                                                                                                                                         
            "?sap-client=" + _getSapClient() +                                                                                                                                                                                                                 
            "&ReqId="     + encodeURIComponent(sReqId) +                                                                                                                                                                                                       
            "&ConfId="    + encodeURIComponent(sConfId) +                                                                                                                                                                                                      
            "&ConfName="  + encodeURIComponent(sConfName) +                                                                                                                                                                                                    
            "&ModuleId="  + encodeURIComponent(sModuleId) +                                                                                                                                                                                                    
            "&TargetCds=" + encodeURIComponent(sTargetCds) +                                                                                                                                                                                                   
            "&EnvId="     + encodeURIComponent(sEnvId) +                                                                                                                                                                                                       
            "&Status="    + encodeURIComponent(sStatus);                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
          console.log("OpenConfigAction navigating to:", sUrl);                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
          BusyIndicator.hide();                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
          const oLink = document.createElement("a");                                                                                                                                                                                                           
          oLink.href = sUrl;                                                                                                                                                                                                                                   
          oLink.target = "_self";                                                                                                                                                                                                                              
          oLink.rel = "noopener noreferrer";                                                                                                                                                                                                                   
          document.body.appendChild(oLink);                                                                                                                                                                                                                    
          oLink.click();                                                                                                                                                                                                                                       
          document.body.removeChild(oLink);                                                                                                                                                                                                                    
        } catch (e) {                                                                                                                                                                                                                                          
          BusyIndicator.hide();                                                                                                                                                                                                                                
          console.error("OpenConfigAction error:", e);                                                                                                                                                                                                         
          MessageBox.error(e?.message || "Open Config failed");                                                                                                                                                                                                
        }                                                                                                                                                                                                                                                      
      },                                                                                                                                                                                                                                                       
    };                                                                                                                                                                                                                                                         
  },                                                                                                                                                                                                                                                           
);                                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               