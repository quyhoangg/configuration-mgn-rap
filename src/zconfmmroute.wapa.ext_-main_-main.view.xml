<mvc:View                                                                                                                                                                                                                                                      
    controllerName="zgsp26.conf.mng.mmroutes.confmngfemmroutes.ext.main.Main"                                                                                                                                                                                  
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core">                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
    <Page id="mainPage" title="MM Route Inline Maintenance">                                                                                                                                                                                                   
        <content>                                                                                                                                                                                                                                              
            <VBox class="sapUiSmallMargin">                                                                                                                                                                                                                    
            <VBox class="sapUiSmallMarginBottom">                                                                                                                                                                                                              
                <Toolbar>                                                                                                                                                                                                                                      
                    <Title text="Filters" level="H3"/>                                                                                                                                                                                                         
                    <ToolbarSpacer/>                                                                                                                                                                                                                           
                    <Button text="Go" type="Emphasized" press=".onSearch"/>                                                                                                                                                                                    
                    <Button text="Clear" press=".onClearFilters"/>                                                                                                                                                                                             
                </Toolbar>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                <HBox wrap="Wrap" class="sapUiTinyMarginTop sapUiTinyMarginBottom">                                                                                                                                                                            
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Search"/>                                                                                                                                                                                                                 
                        <SearchField                                                                                                                                                                                                                           
                            id="searchField"                                                                                                                                                                                                                   
                            width="16rem"                                                                                                                                                                                                                      
                            search=".onSearch"/>                                                                                                                                                                                                               
                    </VBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Environment"/>                                                                                                                                                                                                            
                        <Input                                                                                                                                                                                                                                 
                            id="envInput"                                                                                                                                                                                                                      
                            width="12rem"                                                                                                                                                                                                                      
                            value="{filter>/EnvId}"                                                                                                                                                                                                            
                            showValueHelp="true"                                                                                                                                                                                                               
                            valueHelpRequest=".onValueHelpEnv"/>                                                                                                                                                                                               
                    </VBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Plant"/>                                                                                                                                                                                                                  
                        <Input                                                                                                                                                                                                                                 
                            id="plantInput"                                                                                                                                                                                                                    
                            width="12rem"                                                                                                                                                                                                                      
                            value="{filter>/PlantId}"                                                                                                                                                                                                          
                            showValueHelp="true"                                                                                                                                                                                                               
                            valueHelpRequest=".onValueHelpPlant"/>                                                                                                                                                                                             
                    </VBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Sending Warehouse"/>                                                                                                                                                                                                      
                        <Input                                                                                                                                                                                                                                 
                            id="sendWhInput"                                                                                                                                                                                                                   
                            width="12rem"                                                                                                                                                                                                                      
                            value="{filter>/SendWh}"/>                                                                                                                                                                                                         
                    </VBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Receiving Warehouse"/>                                                                                                                                                                                                    
                        <Input                                                                                                                                                                                                                                 
                            id="receiveWhInput"                                                                                                                                                                                                                
                            width="12rem"                                                                                                                                                                                                                      
                            value="{filter>/ReceiveWh}"/>                                                                                                                                                                                                      
                    </VBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Transport Mode"/>                                                                                                                                                                                                         
                        <Input                                                                                                                                                                                                                                 
                            id="transModeInput"                                                                                                                                                                                                                
                            width="12rem"                                                                                                                                                                                                                      
                            value="{filter>/TransMode}"/>                                                                                                                                                                                                      
                    </VBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Allowed"/>                                                                                                                                                                                                                
                        <Select                                                                                                                                                                                                                                
                            id="allowedSelect"                                                                                                                                                                                                                 
                            width="10rem"                                                                                                                                                                                                                      
                            selectedKey="{filter>/Allowed}">                                                                                                                                                                                                   
                            <items>                                                                                                                                                                                                                            
                                <core:Item key="" text="All"/>                                                                                                                                                                                                 
                                <core:Item key="X" text="Yes"/>                                                                                                                                                                                                
                                <core:Item key="false" text="No"/>                                                                                                                                                                                             
                            </items>                                                                                                                                                                                                                           
                        </Select>                                                                                                                                                                                                                              
                    </VBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Inspector"/>                                                                                                                                                                                                              
                        <Input                                                                                                                                                                                                                                 
                            id="inspectorInput"                                                                                                                                                                                                                
                            width="12rem"                                                                                                                                                                                                                      
                            value="{filter>/InspectorId}"/>                                                                                                                                                                                                    
                    </VBox>                                                                                                                                                                                                                                    
                </HBox>                                                                                                                                                                                                                                        
            </VBox>                                                                                                                                                                                                                                            
                <Toolbar>                                                                                                                                                                                                                                      
                    <Title text="Warehouse Routes" level="H2"/>                                                                                                                                                                                                
                    <ToolbarSpacer/>                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
                    <Button                                                                                                                                                                                                                                    
                        text="Edit"                                                                                                                                                                                                                            
                        press=".onEdit"                                                                                                                                                                                                                        
                        visible="{= !${ui>/editMode} }"/>                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
                    <Button                                                                                                                                                                                                                                    
                        text="Create"                                                                                                                                                                                                                          
                        press=".onCreate"                                                                                                                                                                                                                      
                        visible="{ui>/editMode}"/>                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                    <Button                                                                                                                                                                                                                                    
                        text="Delete"                                                                                                                                                                                                                          
                        press=".onDelete"                                                                                                                                                                                                                      
                        visible="{ui>/editMode}"/>                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                    <Button                                                                                                                                                                                                                                    
                        text="Save"                                                                                                                                                                                                                            
                        type="Emphasized"                                                                                                                                                                                                                      
                        press=".onSave"                                                                                                                                                                                                                        
                        visible="{ui>/editMode}"/>                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                    <Button                                                                                                                                                                                                                                    
                        text="Cancel"                                                                                                                                                                                                                          
                        press=".onCancel"                                                                                                                                                                                                                      
                        visible="{ui>/editMode}"/>                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                    <Button                                                                                                                                                                                                                                    
                        text="Refresh"                                                                                                                                                                                                                         
                        press=".onRefresh"                                                                                                                                                                                                                     
                        visible="{= !${ui>/editMode} }"/>                                                                                                                                                                                                      
                </Toolbar>                                                                                                                                                                                                                                     
                <Table                                                                                                                                                                                                                                         
                    id="routesTable"                                                                                                                                                                                                                           
                    mode="MultiSelect"                                                                                                                                                                                                                         
                    growing="true"                                                                                                                                                                                                                             
                    growingScrollToLoad="true"                                                                                                                                                                                                                 
                    inset="false"                                                                                                                                                                                                                              
                    items="{                                                                                                                                                                                                                                   
                        path: '/MMRouteConf'                                                                                                                                                                                                                   
                    }">                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                    <columns>                                                                                                                                                                                                                                  
                        <Column><Text text="Environment"/></Column>                                                                                                                                                                                            
                        <Column><Text text="Plant"/></Column>                                                                                                                                                                                                  
                        <Column><Text text="Sending Warehouse"/></Column>                                                                                                                                                                                      
                        <Column><Text text="Receiving Warehouse"/></Column>                                                                                                                                                                                    
                        <Column><Text text="Transport Mode"/></Column>                                                                                                                                                                                         
                        <Column><Text text="Allowed"/></Column>                                                                                                                                                                                                
                        <Column><Text text="Inspector"/></Column>                                                                                                                                                                                              
                        <Column><Text text="Version"/></Column>                                                                                                                                                                                                
                    </columns>                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
                    <items>                                                                                                                                                                                                                                    
                        <ColumnListItem>                                                                                                                                                                                                                       
                            <cells>                                                                                                                                                                                                                            
                                <Input value="{EnvId}" editable="{ui>/editMode}"/>                                                                                                                                                                             
                                <Input value="{PlantId}" editable="{ui>/editMode}"/>                                                                                                                                                                           
                                <Input value="{SendWh}" editable="{ui>/editMode}"/>                                                                                                                                                                            
                                <Input value="{ReceiveWh}" editable="{ui>/editMode}"/>                                                                                                                                                                         
                                <Input value="{TransMode}" editable="{ui>/editMode}"/>                                                                                                                                                                         
                                <CheckBox selected="{IsAllowed}" enabled="false"/>                                                                                                                                                                             
                                <Input value="{InspectorId}" editable="false"/>                                                                                                                                                                                
                                <Input value="{VersionNo}" type="Number" editable="false"/>                                                                                                                                                                    
                            </cells>                                                                                                                                                                                                                           
                        </ColumnListItem>                                                                                                                                                                                                                      
                    </items>                                                                                                                                                                                                                                   
                </Table>                                                                                                                                                                                                                                       
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    