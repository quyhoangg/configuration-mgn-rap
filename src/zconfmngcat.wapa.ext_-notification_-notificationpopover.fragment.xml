<core:FragmentDefinition                                                                                                                                                                                                                                       
  xmlns="sap.m"                                                                                                                                                                                                                                                
  xmlns:core="sap.ui.core">                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
  <Popover                                                                                                                                                                                                                                                     
    id="notifPopover"                                                                                                                                                                                                                                          
    placement="Bottom"                                                                                                                                                                                                                                         
    contentWidth="28rem"                                                                                                                                                                                                                                       
    contentHeight="24rem"                                                                                                                                                                                                                                      
    showHeader="false"                                                                                                                                                                                                                                         
    verticalScrolling="true"                                                                                                                                                                                                                                   
    horizontalScrolling="false"                                                                                                                                                                                                                                
    afterClose=".onNotifPopoverClose">                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    <customHeader>                                                                                                                                                                                                                                             
      <Toolbar style="Clear" height="2.75rem">                                                                                                                                                                                                                 
        <Title text="Notifications" level="H5" />                                                                                                                                                                                                              
        <ToolbarSpacer />                                                                                                                                                                                                                                      
        <Button                                                                                                                                                                                                                                                
          text="Mark all read"                                                                                                                                                                                                                                 
          type="Transparent"                                                                                                                                                                                                                                   
          press=".onMarkAllRead"                                                                                                                                                                                                                               
          visible="{= ${notif>/unreadCount} > 0}" />                                                                                                                                                                                                           
        <Button                                                                                                                                                                                                                                                
          icon="sap-icon://delete"                                                                                                                                                                                                                             
          type="Transparent"                                                                                                                                                                                                                                   
          tooltip="Clear all"                                                                                                                                                                                                                                  
          press=".onClearAllNotif" />                                                                                                                                                                                                                          
      </Toolbar>                                                                                                                                                                                                                                               
    </customHeader>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
    <List                                                                                                                                                                                                                                                      
      id="notifList"                                                                                                                                                                                                                                           
      items="{notif>/notifications}"                                                                                                                                                                                                                           
      noDataText="No new notifications"                                                                                                                                                                                                                        
      showSeparators="Inner">                                                                                                                                                                                                                                  
      <CustomListItem                                                                                                                                                                                                                                          
        type="Active"                                                                                                                                                                                                                                          
        press=".onNotifItemPress"                                                                                                                                                                                                                              
        class="{= ${notif>read} ? 'confNotifItem confNotifItem--read' : 'confNotifItem confNotifItem--unread'}">                                                                                                                                               
        <HBox alignItems="Start" class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTopBottom">                                                                                                                                                  
                                                                                                                                                                                                                                                               
          <!-- Unread blue dot -->                                                                                                                                                                                                                             
          <core:HTML content="{= ${notif>read} ? '&lt;span class=&quot;confNotifDot confNotifDot--hidden&quot;&gt;&lt;/span&gt;' : '&lt;span class=&quot;confNotifDot&quot;&gt;&lt;/span&gt;'}" />                                                             
                                                                                                                                                                                                                                                               
          <!-- Status icon -->                                                                                                                                                                                                                                 
          <core:Icon                                                                                                                                                                                                                                           
            src="{notif>icon}"                                                                                                                                                                                                                                 
            color="{= ${notif>state} === 'Error' ? '#bb0000' : (${notif>state} === 'Success' ? '#107e3e' : (${notif>state} === 'Warning' ? '#e9730c' : '#0070f2'))}"                                                                                           
            size="1.1rem"                                                                                                                                                                                                                                      
            class="sapUiSmallMarginEnd sapUiTinyMarginTop" />                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
          <!-- Text content -->                                                                                                                                                                                                                                
          <VBox class="confNotifText" fitContainer="true">                                                                                                                                                                                                     
            <Text                                                                                                                                                                                                                                              
              text="{notif>title}"                                                                                                                                                                                                                             
              maxLines="1"                                                                                                                                                                                                                                     
              class="{= ${notif>read} ? 'confNotifTitle--read' : 'confNotifTitle--unread'}" />                                                                                                                                                                 
            <Text                                                                                                                                                                                                                                              
              text="{notif>message}"                                                                                                                                                                                                                           
              maxLines="2"                                                                                                                                                                                                                                     
              wrapping="true"                                                                                                                                                                                                                                  
              class="confNotifMessage" />                                                                                                                                                                                                                      
          </VBox>                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
          <!-- Time + unread label -->                                                                                                                                                                                                                         
          <VBox class="confNotifMeta" justifyContent="Start" alignItems="End">                                                                                                                                                                                 
            <Text text="{notif>time}" textAlign="End" class="confNotifTime" />                                                                                                                                                                                 
            <Text                                                                                                                                                                                                                                              
              text="NEW"                                                                                                                                                                                                                                       
              visible="{= !${notif>read} }"                                                                                                                                                                                                                    
              class="confNotifNewBadge" />                                                                                                                                                                                                                     
          </VBox>                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
        </HBox>                                                                                                                                                                                                                                                
      </CustomListItem>                                                                                                                                                                                                                                        
    </List>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
  </Popover>                                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               