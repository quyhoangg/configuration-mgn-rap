            sBase + "FILimitConf(" + sDraftKey + ",IsActiveEntity=false)/" +                                                                                                                                                                                   
            sNs + ".Activate?sap-client=" + sSapClient;                                                                                                                                                                                                        
          const oActResp = await fetch(sActivateUrl, {                                                                                                                                                                                                         
            method: "POST",                                                                                                                                                                                                                                    
            headers: oHeaders,                                                                                                                                                                                                                                 
