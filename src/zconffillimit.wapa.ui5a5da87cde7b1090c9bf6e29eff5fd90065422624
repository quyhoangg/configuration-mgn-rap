          // 2. Activate draft → persists to zfilimitconf_req as active entity                                                                                                                                                                                 
          // Key must include all 3 entity keys + IsActiveEntity (backend has composite key)                                                                                                                                                                   
          const sDraftKey =                                                                                                                                                                                                                                    
