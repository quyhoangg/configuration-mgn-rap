sap.ui.define(                                                                                                                                                                                                                                                 
  [                                                                                                                                                                                                                                                            
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/m/MessageToast",                                                                                                                                                                                                                                      
    "sap/ui/core/routing/HashChanger",                                                                                                                                                                                                                         
    "sap/ui/core/Fragment",                                                                                                                                                                                                                                    
    "zgsp26/conf/mng/confmngcatalog/ext/notification/NotificationService",                                                                                                                                                                                     
  ],                                                                                                                                                                                                                                                           
  function (Controller, JSONModel, MessageToast, HashChanger, Fragment, NotificationService) {                                                                                                                                                                 
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    function _getSapClient() {                                                                                                                                                                                                                                 
      return new URLSearchParams(window.location.search).get("sap-client") || "324";                                                                                                                                                                           
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    function _formatDate(sVal) {                                                                                                                                                                                                                               
      if (!sVal) return "–";                                                                                                                                                                                                                                   
      try {                                                                                                                                                                                                                                                    
        return new Date(sVal).toLocaleDateString("en-US", {                                                                                                                                                                                                    
          month: "short", day: "numeric", year: "numeric",                                                                                                                                                                                                     
        });                                                                                                                                                                                                                                                    
      } catch (e) { return sVal; }                                                                                                                                                                                                                             
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    var MODULE_COLOR_MAP = {                                                                                                                                                                                                                                   
      MM: "Information",                                                                                                                                                                                                                                       
      SD: "Success",                                                                                                                                                                                                                                           
      FI: "Warning",                                                                                                                                                                                                                                           
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    function _mapRow(oItem) {                                                                                                                                                                                                                                  
      return {                                                                                                                                                                                                                                                 
        ConfId:        oItem.ConfId,                                                                                                                                                                                                                           
        ConfName:      oItem.ConfName      || "–",                                                                                                                                                                                                             
        ModuleId:      oItem.ModuleId      || "–",                                                                                                                                                                                                             
        ConfType:      oItem.ConfType      || "–",                                                                                                                                                                                                             
        Description:   oItem.Description   || "–",                                                                                                                                                                                                             
        TargetCds:     oItem.TargetCds     || "–",                                                                                                                                                                                                             
        IsActive:      !!oItem.IsActive,                                                                                                                                                                                                                       
        StatusText:    oItem.IsActive ? "Active" : "Inactive",                                                                                                                                                                                                 
        StatusState:   oItem.IsActive ? "Success" : "None",                                                                                                                                                                                                    
        ModuleState:   MODULE_COLOR_MAP[oItem.ModuleId] || "None",                                                                                                                                                                                             
        CreatedAtText: _formatDate(oItem.CreatedAt),                                                                                                                                                                                                           
      };                                                                                                                                                                                                                                                       
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    return Controller.extend("zgsp26.conf.mng.confmngcatalog.ext.catalogList.CatalogList", {                                                                                                                                                                   
                                                                                                                                                                                                                                                               
      onInit: function () {                                                                                                                                                                                                                                    
        var oModel = new JSONModel({                                                                                                                                                                                                                           
          loading:      true,                                                                                                                                                                                                                                  
          catalogs:     [],                                                                                                                                                                                                                                    
          allCatalogs:  [],                                                                                                                                                                                                                                    
          activeFilter: "ALL",                                                                                                                                                                                                                                 
          kpi: { total: 0, active: 0, inactive: 0, mm: 0, sd: 0, fi: 0 },                                                                                                                                                                                      
        });                                                                                                                                                                                                                                                    
        this.getView().setModel(oModel, "catalog");                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
        // ── Notification service ─────────────────────────────────────────                                                                                                                                                                                   
        var oNotifModel = NotificationService.init(_getSapClient());                                                                                                                                                                                           
        this.getView().setModel(oNotifModel, "notif");                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
        oNotifModel.attachPropertyChange(function () {                                                                                                                                                                                                         
          this._syncBellBadge();                                                                                                                                                                                                                               
        }, this);                                                                                                                                                                                                                                              
        this._iBadgeTimer = setInterval(function () {                                                                                                                                                                                                          
          this._syncBellBadge();                                                                                                                                                                                                                               
        }.bind(this), 2000);                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
        this._loadCatalogs();                                                                                                                                                                                                                                  
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      onExit: function () {                                                                                                                                                                                                                                    
        if (this._iBadgeTimer) { clearInterval(this._iBadgeTimer); }                                                                                                                                                                                           
        NotificationService.destroy();                                                                                                                                                                                                                         
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      // ── Bell badge ───────────────────────────────────────────────────                                                                                                                                                                                     
      _syncBellBadge: function () {                                                                                                                                                                                                                            
        var oNotifModel = this.getView().getModel("notif");                                                                                                                                                                                                    
        if (!oNotifModel) return;                                                                                                                                                                                                                              
        var iCount = oNotifModel.getProperty("/unreadCount") || 0;                                                                                                                                                                                             
        var oBell  = this.byId("notifBellBtn");                                                                                                                                                                                                                
        if (!oBell) return;                                                                                                                                                                                                                                    
        var oDom = oBell.getDomRef();                                                                                                                                                                                                                          
        if (!oDom) {                                                                                                                                                                                                                                           
          setTimeout(function () {                                                                                                                                                                                                                             
            var oDom2 = oBell.getDomRef();                                                                                                                                                                                                                     
            if (!oDom2) return;                                                                                                                                                                                                                                
            oDom2.setAttribute("data-notif-count", iCount > 0 ? (iCount > 99 ? "99+" : String(iCount)) : "");                                                                                                                                                  
            oDom2.classList.toggle("confNotifBellActive", iCount > 0);                                                                                                                                                                                         
          }, 300);                                                                                                                                                                                                                                             
          return;                                                                                                                                                                                                                                              
        }                                                                                                                                                                                                                                                      
        oDom.setAttribute("data-notif-count", iCount > 0 ? (iCount > 99 ? "99+" : String(iCount)) : "");                                                                                                                                                       
        oDom.classList.toggle("confNotifBellActive", iCount > 0);                                                                                                                                                                                              
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      // ── Bell press → open popover ────────────────────────────────────                                                                                                                                                                                     
      onNotifBellPress: function (oEvent) {                                                                                                                                                                                                                    
        var oBtn  = oEvent.getSource();                                                                                                                                                                                                                        
        var oView = this.getView();                                                                                                                                                                                                                            
        if (!this._oNotifPopover) {                                                                                                                                                                                                                            
          Fragment.load({                                                                                                                                                                                                                                      
            id:         oView.getId(),                                                                                                                                                                                                                         
            name:       "zgsp26.conf.mng.confmngcatalog.ext.notification.NotificationPopover",                                                                                                                                                                 
            controller: this,                                                                                                                                                                                                                                  
          }).then(function (oPopover) {                                                                                                                                                                                                                        
            this._oNotifPopover = oPopover;                                                                                                                                                                                                                    
            oView.addDependent(oPopover);                                                                                                                                                                                                                      
            oPopover.openBy(oBtn);                                                                                                                                                                                                                             
            this._scrollNotifToTop();                                                                                                                                                                                                                          
          }.bind(this));                                                                                                                                                                                                                                       
        } else {                                                                                                                                                                                                                                               
          this._oNotifPopover.openBy(oBtn);                                                                                                                                                                                                                    
          this._scrollNotifToTop();                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      _scrollNotifToTop: function () {                                                                                                                                                                                                                         
        var oList = this.byId("notifList");                                                                                                                                                                                                                    
        if (!oList) return;                                                                                                                                                                                                                                    
        setTimeout(function () {                                                                                                                                                                                                                               
          var oDomRef = oList.getDomRef();                                                                                                                                                                                                                     
          if (oDomRef) { oDomRef.scrollTop = 0; }                                                                                                                                                                                                              
          var oScroller = oList.$().closest(".sapMPopoverCont, .sapMScrollCont")[0];                                                                                                                                                                           
          if (oScroller) { oScroller.scrollTop = 0; }                                                                                                                                                                                                          
        }, 50);                                                                                                                                                                                                                                                
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      onNotifPopoverClose: function () {},                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
      onMarkAllRead: function () {                                                                                                                                                                                                                             
        NotificationService.markAllRead();                                                                                                                                                                                                                     
        this._syncBellBadge();                                                                                                                                                                                                                                 
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      onClearAllNotif: function () {                                                                                                                                                                                                                           
        NotificationService.clearAll();                                                                                                                                                                                                                        
        this._syncBellBadge();                                                                                                                                                                                                                                 
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      onNotifItemPress: function (oEvent) {                                                                                                                                                                                                                    
        var oCtx  = oEvent.getSource().getBindingContext("notif");                                                                                                                                                                                             
        if (!oCtx) return;                                                                                                                                                                                                                                     
        var sId    = oCtx.getProperty("id");                                                                                                                                                                                                                   
        var sReqId = oCtx.getProperty("ReqId");                                                                                                                                                                                                                
        var sEnvId = oCtx.getProperty("EnvId") || "DEV";                                                                                                                                                                                                       
        NotificationService.markRead(sId);                                                                                                                                                                                                                     
        this._syncBellBadge();                                                                                                                                                                                                                                 
        if (this._oNotifPopover) { this._oNotifPopover.close(); }                                                                                                                                                                                              
        if (sReqId) {                                                                                                                                                                                                                                          
          // Navigate to request app to view the request detail                                                                                                                                                                                                
          var sMode = localStorage.getItem("conf-mng-nav-mode") ||                                                                                                                                                                                             
            (window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1"                                                                                                                                                              
              ? "local" : "deploy");                                                                                                                                                                                                                           
          var sBase = sMode === "local"                                                                                                                                                                                                                        
            ? "http://localhost:8081/index.html"                                                                                                                                                                                                               
            : window.location.origin + "/sap/bc/ui5_ui5/sap/zconf_req_ui/index.html";                                                                                                                                                                          
          window.open(                                                                                                                                                                                                                                         
            sBase + "?sap-client=" + _getSapClient() +                                                                                                                                                                                                         
              "&ReqId=" + encodeURIComponent(sReqId) +                                                                                                                                                                                                         
              "&EnvId=" + encodeURIComponent(sEnvId),                                                                                                                                                                                                          
            "_self"                                                                                                                                                                                                                                            
          );                                                                                                                                                                                                                                                   
        }                                                                                                                                                                                                                                                      
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      _loadCatalogs: function () {                                                                                                                                                                                                                             
        var oModel  = this.getView().getModel("catalog");                                                                                                                                                                                                      
        var sClient = _getSapClient();                                                                                                                                                                                                                         
        oModel.setProperty("/loading", true);                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
        var sUrl =                                                                                                                                                                                                                                             
          "/sap/opu/odata4/sap/zui_conf_catalog/srvd/sap/zsd_conf_catalog/0001/" +                                                                                                                                                                             
          "ConfigCatalog" +                                                                                                                                                                                                                                    
          "?$select=ConfId,ConfName,ModuleId,ConfType,Description,TargetCds,IsActive,CreatedAt" +                                                                                                                                                              
          "&$orderby=ModuleId asc,ConfName asc" +                                                                                                                                                                                                              
          "&sap-client=" + sClient;                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
        fetch(sUrl, {                                                                                                                                                                                                                                          
          credentials: "include",                                                                                                                                                                                                                              
          headers: { Accept: "application/json", "X-Requested-With": "XMLHttpRequest" },                                                                                                                                                                       
        })                                                                                                                                                                                                                                                     
          .then(function (r) { return r.json(); })                                                                                                                                                                                                             
          .then(function (data) {                                                                                                                                                                                                                              
            var aAll = (data.value || []).map(_mapRow);                                                                                                                                                                                                        
            oModel.setProperty("/allCatalogs", aAll);                                                                                                                                                                                                          
            oModel.setProperty("/catalogs", aAll);                                                                                                                                                                                                             
            oModel.setProperty("/kpi", {                                                                                                                                                                                                                       
              total:    aAll.length,                                                                                                                                                                                                                           
              active:   aAll.filter(function (r) { return r.IsActive; }).length,                                                                                                                                                                               
              inactive: aAll.filter(function (r) { return !r.IsActive; }).length,                                                                                                                                                                              
              mm:       aAll.filter(function (r) { return r.ModuleId === "MM"; }).length,                                                                                                                                                                      
              sd:       aAll.filter(function (r) { return r.ModuleId === "SD"; }).length,                                                                                                                                                                      
              fi:       aAll.filter(function (r) { return r.ModuleId === "FI"; }).length,                                                                                                                                                                      
            });                                                                                                                                                                                                                                                
            oModel.setProperty("/loading", false);                                                                                                                                                                                                             
          })                                                                                                                                                                                                                                                   
          .catch(function () {                                                                                                                                                                                                                                 
            oModel.setProperty("/loading", false);                                                                                                                                                                                                             
            MessageToast.show("Failed to load catalogs");                                                                                                                                                                                                      
          });                                                                                                                                                                                                                                                  
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      _applyFilters: function () {                                                                                                                                                                                                                             
        var oModel       = this.getView().getModel("catalog");                                                                                                                                                                                                 
        var sModuleKey   = oModel.getProperty("/activeFilter");                                                                                                                                                                                                
        var sSearchQuery = (this._sSearchQuery || "").toLowerCase();                                                                                                                                                                                           
        var aAll         = oModel.getProperty("/allCatalogs");                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
        var aFiltered = aAll.filter(function (r) {                                                                                                                                                                                                             
          var bModule = sModuleKey === "ALL" || r.ModuleId === sModuleKey;                                                                                                                                                                                     
          var bSearch = !sSearchQuery ||                                                                                                                                                                                                                       
            (r.ConfName    || "").toLowerCase().includes(sSearchQuery) ||                                                                                                                                                                                      
            (r.ModuleId    || "").toLowerCase().includes(sSearchQuery) ||                                                                                                                                                                                      
            (r.TargetCds   || "").toLowerCase().includes(sSearchQuery) ||                                                                                                                                                                                      
            (r.Description || "").toLowerCase().includes(sSearchQuery);                                                                                                                                                                                        
          return bModule && bSearch;                                                                                                                                                                                                                           
        });                                                                                                                                                                                                                                                    
        oModel.setProperty("/catalogs", aFiltered);                                                                                                                                                                                                            
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      onModuleFilterChange: function (oEvent) {                                                                                                                                                                                                                
        var sKey = oEvent.getParameter("item").getKey();                                                                                                                                                                                                       
        this.getView().getModel("catalog").setProperty("/activeFilter", sKey);                                                                                                                                                                                 
        this._applyFilters();                                                                                                                                                                                                                                  
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      onSearch: function (oEvent) {                                                                                                                                                                                                                            
        this._sSearchQuery = oEvent.getParameter("newValue") || oEvent.getParameter("query") || "";                                                                                                                                                            
        this._applyFilters();                                                                                                                                                                                                                                  
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      onRefresh: function () {                                                                                                                                                                                                                                 
        this._loadCatalogs();                                                                                                                                                                                                                                  
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      onRowPress: function (oEvent) {                                                                                                                                                                                                                          
        var oCtx    = oEvent.getSource().getBindingContext("catalog");                                                                                                                                                                                         
        if (!oCtx) return;                                                                                                                                                                                                                                     
        var sConfId = String(oCtx.getProperty("ConfId"));                                                                                                                                                                                                      
        // Router cannot be reached via getOwnerComponent() because FPM loads this view                                                                                                                                                                        
        // inside a sub-component (sap.fe.core.fpm) that has no router of its own.                                                                                                                                                                             
        // Setting the hash directly is equivalent to navTo("CatalogDetail", {confId})                                                                                                                                                                         
        // and is safe with FLP: hash "ConfigCatalog(guid)" is an OData entity-key pattern,                                                                                                                                                                    
        // not a "SemanticObject-action" pattern, so FLP does NOT intercept it as cross-app navigation.                                                                                                                                                        
        HashChanger.getInstance().setHash("ConfigCatalog(" + sConfId + ")");                                                                                                                                                                                   
      },                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
    });                                                                                                                                                                                                                                                        
  }                                                                                                                                                                                                                                                            
);                                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               