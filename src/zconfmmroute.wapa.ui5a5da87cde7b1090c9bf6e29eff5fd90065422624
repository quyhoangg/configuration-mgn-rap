sap.ui.define(                                                                                                                                                                                                                                                 
  [                                                                                                                                                                                                                                                            
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/m/MessageToast",                                                                                                                                                                                                                                      
    "sap/m/MessageBox",                                                                                                                                                                                                                                        
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/ui/model/Filter",                                                                                                                                                                                                                                     
    "sap/ui/model/FilterOperator",                                                                                                                                                                                                                             
    "sap/m/SelectDialog",                                                                                                                                                                                                                                      
    "sap/m/StandardListItem",                                                                                                                                                                                                                                  
  ],                                                                                                                                                                                                                                                           
  function (                                                                                                                                                                                                                                                   
    Controller,                                                                                                                                                                                                                                                
    MessageToast,                                                                                                                                                                                                                                              
    MessageBox,                                                                                                                                                                                                                                                
    JSONModel,                                                                                                                                                                                                                                                 
    Filter,                                                                                                                                                                                                                                                    
    FilterOperator,                                                                                                                                                                                                                                            
    SelectDialog,                                                                                                                                                                                                                                              
    StandardListItem,                                                                                                                                                                                                                                          
  ) {                                                                                                                                                                                                                                                          
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend(                                                                                                                                                                                                                                  
      "zgsp26.conf.mng.mmroutes.confmngfemmroutes.ext.main.Main",                                                                                                                                                                                              
      {                                                                                                                                                                                                                                                        
        onInit: function () {                                                                                                                                                                                                                                  
          this._oModel =                                                                                                                                                                                                                                       
            this.getView().getModel() || this.getOwnerComponent().getModel();                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
          const oUIModel = new JSONModel({                                                                                                                                                                                                                     
            editMode: false,                                                                                                                                                                                                                                   
          });                                                                                                                                                                                                                                                  
          this.getView().setModel(oUIModel, "ui");                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
          const oFilterModel = new JSONModel({                                                                                                                                                                                                                 
            EnvId: "",                                                                                                                                                                                                                                         
            PlantId: "",                                                                                                                                                                                                                                       
            SendWh: "",                                                                                                                                                                                                                                        
            ReceiveWh: "",                                                                                                                                                                                                                                     
            TransMode: "",                                                                                                                                                                                                                                     
            Allowed: "",                                                                                                                                                                                                                                       
            InspectorId: "",                                                                                                                                                                                                                                   
            Search: "",                                                                                                                                                                                                                                        
          });                                                                                                                                                                                                                                                  
          this.getView().setModel(oFilterModel, "filter");                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        onEdit: function () {                                                                                                                                                                                                                                  
          this.getView().getModel("ui").setProperty("/editMode", true);                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        onCancel: function () {                                                                                                                                                                                                                                
          const oModel =                                                                                                                                                                                                                                       
            this.getView().getModel() || this.getOwnerComponent().getModel();                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
          try {                                                                                                                                                                                                                                                
            oModel.resetChanges("$auto");                                                                                                                                                                                                                      
          } catch (e) {                                                                                                                                                                                                                                        
            console.warn(e);                                                                                                                                                                                                                                   
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          this.getView().getModel("ui").setProperty("/editMode", false);                                                                                                                                                                                       
          MessageToast.show("Đã hủy thay đổi");                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        onCreate: async function () {                                                                                                                                                                                                                          
          try {                                                                                                                                                                                                                                                
            const oTable = this.byId("routesTable");                                                                                                                                                                                                           
            const oBinding = oTable.getBinding("items");                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            oBinding.create({                                                                                                                                                                                                                                  
              EnvId: "",                                                                                                                                                                                                                                       
              PlantId: "",                                                                                                                                                                                                                                     
              SendWh: "",                                                                                                                                                                                                                                      
              ReceiveWh: "",                                                                                                                                                                                                                                   
              TransMode: "",                                                                                                                                                                                                                                   
              IsAllowed: false,                                                                                                                                                                                                                                
              InspectorId: "",                                                                                                                                                                                                                                 
              VersionNo: 1,                                                                                                                                                                                                                                    
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            MessageToast.show("Đã tạo dòng mới");                                                                                                                                                                                                              
          } catch (e) {                                                                                                                                                                                                                                        
            console.error(e);                                                                                                                                                                                                                                  
            MessageBox.error("Không tạo được dòng mới");                                                                                                                                                                                                       
          }                                                                                                                                                                                                                                                    
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        onDelete: function () {                                                                                                                                                                                                                                
          const oTable = this.byId("routesTable");                                                                                                                                                                                                             
          const aItems = oTable.getSelectedItems();                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
          if (!aItems.length) {                                                                                                                                                                                                                                
            MessageToast.show("Select row to delete");                                                                                                                                                                                                         
            return;                                                                                                                                                                                                                                            
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          MessageBox.confirm("Delete selected rows?", {                                                                                                                                                                                                        
            onClose: async (sAction) => {                                                                                                                                                                                                                      
              if (sAction === "OK") {                                                                                                                                                                                                                          
                for (const oItem of aItems) {                                                                                                                                                                                                                  
                  await oItem.getBindingContext().delete("$auto");                                                                                                                                                                                             
                }                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                MessageToast.show("Deleted");                                                                                                                                                                                                                  
              }                                                                                                                                                                                                                                                
            },                                                                                                                                                                                                                                                 
          });                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        onSave: async function () {                                                                                                                                                                                                                            
          const oView = this.getView();                                                                                                                                                                                                                        
          const oModel = oView.getModel();                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
          oView.setBusy(true);                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
          try {                                                                                                                                                                                                                                                
            await oModel.submitBatch("$auto");                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            MessageToast.show("Saved successfully");                                                                                                                                                                                                           
          } catch (e) {                                                                                                                                                                                                                                        
            MessageBox.error("Save failed");                                                                                                                                                                                                                   
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          oView.setBusy(false);                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        onRefresh: function () {                                                                                                                                                                                                                               
          const oBinding = this.byId("routesTable").getBinding("items");                                                                                                                                                                                       
          if (oBinding) {                                                                                                                                                                                                                                      
            oBinding.refresh();                                                                                                                                                                                                                                
          }                                                                                                                                                                                                                                                    
          MessageToast.show("Đã refresh");                                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
        onSearch: function () {                                                                                                                                                                                                                                
          const oTable = this.byId("routesTable");                                                                                                                                                                                                             
          const oBinding = oTable.getBinding("items");                                                                                                                                                                                                         
          const oFilterData = this.getView().getModel("filter").getData();                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
          const aFilters = [];                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
          if (oFilterData.EnvId) {                                                                                                                                                                                                                             
            aFilters.push(                                                                                                                                                                                                                                     
              new Filter("EnvId", FilterOperator.Contains, oFilterData.EnvId),                                                                                                                                                                                 
            );                                                                                                                                                                                                                                                 
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          if (oFilterData.PlantId) {                                                                                                                                                                                                                           
            aFilters.push(                                                                                                                                                                                                                                     
              new Filter(                                                                                                                                                                                                                                      
                "PlantId",                                                                                                                                                                                                                                     
                FilterOperator.Contains,                                                                                                                                                                                                                       
                oFilterData.PlantId,                                                                                                                                                                                                                           
              ),                                                                                                                                                                                                                                               
            );                                                                                                                                                                                                                                                 
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          if (oFilterData.SendWh) {                                                                                                                                                                                                                            
            aFilters.push(                                                                                                                                                                                                                                     
              new Filter("SendWh", FilterOperator.Contains, oFilterData.SendWh),                                                                                                                                                                               
            );                                                                                                                                                                                                                                                 
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          if (oFilterData.ReceiveWh) {                                                                                                                                                                                                                         
            aFilters.push(                                                                                                                                                                                                                                     
              new Filter(                                                                                                                                                                                                                                      
                "ReceiveWh",                                                                                                                                                                                                                                   
                FilterOperator.Contains,                                                                                                                                                                                                                       
                oFilterData.ReceiveWh,                                                                                                                                                                                                                         
              ),                                                                                                                                                                                                                                               
            );                                                                                                                                                                                                                                                 
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          if (oFilterData.TransMode) {                                                                                                                                                                                                                         
            aFilters.push(                                                                                                                                                                                                                                     
              new Filter(                                                                                                                                                                                                                                      
                "TransMode",                                                                                                                                                                                                                                   
                FilterOperator.Contains,                                                                                                                                                                                                                       
                oFilterData.TransMode,                                                                                                                                                                                                                         
              ),                                                                                                                                                                                                                                               
            );                                                                                                                                                                                                                                                 
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          if (oFilterData.InspectorId) {                                                                                                                                                                                                                       
            aFilters.push(                                                                                                                                                                                                                                     
              new Filter(                                                                                                                                                                                                                                      
                "InspectorId",                                                                                                                                                                                                                                 
                FilterOperator.Contains,                                                                                                                                                                                                                       
                oFilterData.InspectorId,                                                                                                                                                                                                                       
              ),                                                                                                                                                                                                                                               
            );                                                                                                                                                                                                                                                 
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          if (oFilterData.Allowed === "X") {                                                                                                                                                                                                                   
            aFilters.push(new Filter("IsAllowed", FilterOperator.EQ, true));                                                                                                                                                                                   
          } else if (oFilterData.Allowed === "false") {                                                                                                                                                                                                        
            aFilters.push(new Filter("IsAllowed", FilterOperator.EQ, false));                                                                                                                                                                                  
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          const sSearch = this.byId("searchField").getValue();                                                                                                                                                                                                 
          if (sSearch) {                                                                                                                                                                                                                                       
            const oSearchFilter = new Filter({                                                                                                                                                                                                                 
              filters: [                                                                                                                                                                                                                                       
                new Filter("EnvId", FilterOperator.Contains, sSearch),                                                                                                                                                                                         
                new Filter("PlantId", FilterOperator.Contains, sSearch),                                                                                                                                                                                       
                new Filter("SendWh", FilterOperator.Contains, sSearch),                                                                                                                                                                                        
                new Filter("ReceiveWh", FilterOperator.Contains, sSearch),                                                                                                                                                                                     
                new Filter("TransMode", FilterOperator.Contains, sSearch),                                                                                                                                                                                     
                new Filter("InspectorId", FilterOperator.Contains, sSearch),                                                                                                                                                                                   
              ],                                                                                                                                                                                                                                               
              and: false,                                                                                                                                                                                                                                      
            });                                                                                                                                                                                                                                                
            aFilters.push(oSearchFilter);                                                                                                                                                                                                                      
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          oBinding.filter(aFilters);                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
        onClearFilters: function () {                                                                                                                                                                                                                          
          this.getView().getModel("filter").setData({                                                                                                                                                                                                          
            EnvId: "",                                                                                                                                                                                                                                         
            PlantId: "",                                                                                                                                                                                                                                       
            SendWh: "",                                                                                                                                                                                                                                        
            ReceiveWh: "",                                                                                                                                                                                                                                     
            TransMode: "",                                                                                                                                                                                                                                     
            Allowed: "",                                                                                                                                                                                                                                       
            InspectorId: "",                                                                                                                                                                                                                                   
            Search: "",                                                                                                                                                                                                                                        
          });                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
          this.byId("searchField").setValue("");                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
          const oBinding = this.byId("routesTable").getBinding("items");                                                                                                                                                                                       
          if (oBinding) {                                                                                                                                                                                                                                      
            oBinding.filter([]);                                                                                                                                                                                                                               
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          MessageToast.show("Đã xóa bộ lọc");                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
        onValueHelpEnv: function () {                                                                                                                                                                                                                          
          if (!this._oEnvDialog) {                                                                                                                                                                                                                             
            this._oEnvDialog = new SelectDialog({                                                                                                                                                                                                              
              title: "Select Environment",                                                                                                                                                                                                                     
              liveChange: function (oEvent) {                                                                                                                                                                                                                  
                const sValue = oEvent.getParameter("value");                                                                                                                                                                                                   
                const oFilter = new Filter(                                                                                                                                                                                                                    
                  "EnvId",                                                                                                                                                                                                                                     
                  FilterOperator.Contains,                                                                                                                                                                                                                     
                  sValue,                                                                                                                                                                                                                                      
                );                                                                                                                                                                                                                                             
                oEvent.getSource().getBinding("items").filter([oFilter]);                                                                                                                                                                                      
              },                                                                                                                                                                                                                                               
              search: function (oEvent) {                                                                                                                                                                                                                      
                const sValue = oEvent.getParameter("value");                                                                                                                                                                                                   
                const oFilter = new Filter(                                                                                                                                                                                                                    
                  "EnvId",                                                                                                                                                                                                                                     
                  FilterOperator.Contains,                                                                                                                                                                                                                     
                  sValue,                                                                                                                                                                                                                                      
                );                                                                                                                                                                                                                                             
                oEvent.getSource().getBinding("items").filter([oFilter]);                                                                                                                                                                                      
              },                                                                                                                                                                                                                                               
              confirm: (oEvent) => {                                                                                                                                                                                                                           
                const oSelectedItem = oEvent.getParameter("selectedItem");                                                                                                                                                                                     
                if (oSelectedItem) {                                                                                                                                                                                                                           
                  this.getView()                                                                                                                                                                                                                               
                    .getModel("filter")                                                                                                                                                                                                                        
                    .setProperty("/EnvId", oSelectedItem.getTitle());                                                                                                                                                                                          
                }                                                                                                                                                                                                                                              
              },                                                                                                                                                                                                                                               
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            this._oEnvDialog.bindAggregation("items", {                                                                                                                                                                                                        
              path: "/EnvDef",                                                                                                                                                                                                                                 
              template: new StandardListItem({                                                                                                                                                                                                                 
                title: "{EnvId}",                                                                                                                                                                                                                              
                description: "{EnvName}",                                                                                                                                                                                                                      
              }),                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            this.getView().addDependent(this._oEnvDialog);                                                                                                                                                                                                     
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          this._oEnvDialog.open();                                                                                                                                                                                                                             
        },                                                                                                                                                                                                                                                     
        onValueHelpPlant: function () {                                                                                                                                                                                                                        
          if (!this._oPlantDialog) {                                                                                                                                                                                                                           
            this._oPlantDialog = new SelectDialog({                                                                                                                                                                                                            
              title: "Select Plant",                                                                                                                                                                                                                           
              liveChange: function (oEvent) {                                                                                                                                                                                                                  
                const sValue = oEvent.getParameter("value");                                                                                                                                                                                                   
                const oFilter = new Filter(                                                                                                                                                                                                                    
                  "PlantId",                                                                                                                                                                                                                                   
                  FilterOperator.Contains,                                                                                                                                                                                                                     
                  sValue,                                                                                                                                                                                                                                      
                );                                                                                                                                                                                                                                             
                oEvent.getSource().getBinding("items").filter([oFilter]);                                                                                                                                                                                      
              },                                                                                                                                                                                                                                               
              search: function (oEvent) {                                                                                                                                                                                                                      
                const sValue = oEvent.getParameter("value");                                                                                                                                                                                                   
                const oFilter = new Filter(                                                                                                                                                                                                                    
                  "PlantId",                                                                                                                                                                                                                                   
                  FilterOperator.Contains,                                                                                                                                                                                                                     
                  sValue,                                                                                                                                                                                                                                      
                );                                                                                                                                                                                                                                             
                oEvent.getSource().getBinding("items").filter([oFilter]);                                                                                                                                                                                      
              },                                                                                                                                                                                                                                               
              confirm: (oEvent) => {                                                                                                                                                                                                                           
                const oSelectedItem = oEvent.getParameter("selectedItem");                                                                                                                                                                                     
                if (oSelectedItem) {                                                                                                                                                                                                                           
                  this.getView()                                                                                                                                                                                                                               
                    .getModel("filter")                                                                                                                                                                                                                        
                    .setProperty("/PlantId", oSelectedItem.getTitle());                                                                                                                                                                                        
                }                                                                                                                                                                                                                                              
              },                                                                                                                                                                                                                                               
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            this._oPlantDialog.bindAggregation("items", {                                                                                                                                                                                                      
              path: "/PlantUnit",                                                                                                                                                                                                                              
              template: new StandardListItem({                                                                                                                                                                                                                 
                title: "{PlantId}",                                                                                                                                                                                                                            
                description: "{PlantName}",                                                                                                                                                                                                                    
              }),                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            this.getView().addDependent(this._oPlantDialog);                                                                                                                                                                                                   
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          this._oPlantDialog.open();                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
      },                                                                                                                                                                                                                                                       
    );                                                                                                                                                                                                                                                         
  },                                                                                                                                                                                                                                                           
);                                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               