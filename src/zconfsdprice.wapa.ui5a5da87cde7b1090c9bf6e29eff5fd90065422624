              Accept: "application/json",                                                                                                                                                                                                                      
              "X-Requested-With": "XMLHttpRequest",                                                                                                                                                                                                            
            },                                                                                                                                                                                                                                                 
            credentials: "include",                                                                                                                                                                                                                            
          });                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
          if (!oResp.ok) {                                                                                                                                                                                                                                     
            console.error("[SDPrice] SDPriceMain load failed:", oResp.status, oResp.statusText);                                                                                                                                                               
