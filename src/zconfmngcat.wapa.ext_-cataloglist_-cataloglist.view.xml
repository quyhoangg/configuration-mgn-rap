<mvc:View                                                                                                                                                                                                                                                      
  controllerName="zgsp26.conf.mng.confmngcatalog.ext.catalogList.CatalogList"                                                                                                                                                                                  
  xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                  
  xmlns="sap.m"                                                                                                                                                                                                                                                
  xmlns:f="sap.f"                                                                                                                                                                                                                                              
  xmlns:core="sap.ui.core"                                                                                                                                                                                                                                     
  displayBlock="true">                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
  <f:DynamicPage id="catalogListPage" toggleHeaderOnTitleClick="false" headerPinned="true">                                                                                                                                                                    
                                                                                                                                                                                                                                                               
    <!-- ─── Title ─── -->                                                                                                                                                                                                                                     
    <f:title>                                                                                                                                                                                                                                                  
      <f:DynamicPageTitle>                                                                                                                                                                                                                                     
        <f:heading>                                                                                                                                                                                                                                            
          <VBox>                                                                                                                                                                                                                                               
            <HBox alignItems="Center">                                                                                                                                                                                                                         
              <core:Icon src="sap-icon://database" size="1.5rem" color="#0070f2" class="sapUiSmallMarginEnd" />                                                                                                                                                
              <Title text="Configuration Catalog" level="H2" />                                                                                                                                                                                                
            </HBox>                                                                                                                                                                                                                                            
            <Text text="Manage configuration definitions across modules" class="sapUiTinyMarginTop catSubtitle" />                                                                                                                                             
          </VBox>                                                                                                                                                                                                                                              
        </f:heading>                                                                                                                                                                                                                                           
        <f:actions>                                                                                                                                                                                                                                            
          <!-- Notification Bell -->                                                                                                                                                                                                                           
          <Button                                                                                                                                                                                                                                              
            id="notifBellBtn"                                                                                                                                                                                                                                  
            icon="sap-icon://bell"                                                                                                                                                                                                                             
            type="Transparent"                                                                                                                                                                                                                                 
            tooltip="Notifications"                                                                                                                                                                                                                            
            press=".onNotifBellPress"                                                                                                                                                                                                                          
            class="confNotifBell" />                                                                                                                                                                                                                           
          <Button icon="sap-icon://refresh" tooltip="Refresh" type="Transparent" press=".onRefresh" />                                                                                                                                                         
        </f:actions>                                                                                                                                                                                                                                           
        <f:snappedContent>                                                                                                                                                                                                                                     
          <Text text="{= ${catalog>/kpi/total} + ' configurations'}" class="catSubtitle" />                                                                                                                                                                    
        </f:snappedContent>                                                                                                                                                                                                                                    
      </f:DynamicPageTitle>                                                                                                                                                                                                                                    
    </f:title>                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
    <!-- ─── Header: KPI Cards ─── -->                                                                                                                                                                                                                         
    <f:header>                                                                                                                                                                                                                                                 
      <f:DynamicPageHeader pinnable="true">                                                                                                                                                                                                                    
        <HBox wrap="Wrap" alignItems="Stretch" width="100%"                                                                                                                                                                                                    
              class="sapUiSmallMarginBottom sapUiTinyMarginTop">                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
          <!-- ── Left: Module Info Card ── -->                                                                                                                                                                                                                
          <VBox class="catInfoCard sapUiSmallMarginBottom">                                                                                                                                                                                                    
            <HBox alignItems="Center" class="sapUiTinyMarginBottom">                                                                                                                                                                                           
              <core:Icon src="sap-icon://pie-chart" color="#0070f2" size="0.875rem" class="sapUiSmallMarginEnd" />                                                                                                                                             
              <Text text="BY MODULE" class="catSectionLabel" />                                                                                                                                                                                                
            </HBox>                                                                                                                                                                                                                                            
            <HBox alignItems="Center" class="sapUiSmallMarginTop">                                                                                                                                                                                             
              <core:Icon src="sap-icon://inventory" color="#0070f2" size="0.85rem" class="catFieldIcon" />                                                                                                                                                     
              <VBox class="sapUiTinyMarginBegin">                                                                                                                                                                                                              
                <Text text="MM" class="catFieldLabel" />                                                                                                                                                                                                       
                <ObjectStatus text="{catalog>/kpi/mm}" state="Information" inverted="true" />                                                                                                                                                                  
              </VBox>                                                                                                                                                                                                                                          
            </HBox>                                                                                                                                                                                                                                            
            <HBox alignItems="Center" class="sapUiSmallMarginTop">                                                                                                                                                                                             
              <core:Icon src="sap-icon://sales-order" color="#107e3e" size="0.85rem" class="catFieldIcon" />                                                                                                                                                   
              <VBox class="sapUiTinyMarginBegin">                                                                                                                                                                                                              
                <Text text="SD" class="catFieldLabel" />                                                                                                                                                                                                       
                <ObjectStatus text="{catalog>/kpi/sd}" state="Success" inverted="true" />                                                                                                                                                                      
              </VBox>                                                                                                                                                                                                                                          
            </HBox>                                                                                                                                                                                                                                            
            <HBox alignItems="Center" class="sapUiSmallMarginTop">                                                                                                                                                                                             
              <core:Icon src="sap-icon://money-bills" color="#e9730c" size="0.85rem" class="catFieldIcon" />                                                                                                                                                   
              <VBox class="sapUiTinyMarginBegin">                                                                                                                                                                                                              
                <Text text="FI" class="catFieldLabel" />                                                                                                                                                                                                       
                <ObjectStatus text="{catalog>/kpi/fi}" state="Warning" inverted="true" />                                                                                                                                                                      
              </VBox>                                                                                                                                                                                                                                          
            </HBox>                                                                                                                                                                                                                                            
          </VBox>                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
          <!-- ── Right: KPI Numbers ── -->                                                                                                                                                                                                                    
          <HBox wrap="NoWrap" alignItems="Stretch" class="catKpiContainer">                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            <VBox alignItems="Center" justifyContent="Center" class="catKpiCard catKpiCard--blue">                                                                                                                                                             
              <Text text="{catalog>/kpi/total}" class="catKpiNumber catKpiNumber--blue" />                                                                                                                                                                     
              <core:Icon src="sap-icon://database" color="#0070f2" size="0.9rem" class="catKpiIconSpacer" />                                                                                                                                                   
              <Text text="Total" class="catKpiLabel catKpiLabel--blue" />                                                                                                                                                                                      
            </VBox>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            <VBox alignItems="Center" justifyContent="Center" class="catKpiCard catKpiCard--green">                                                                                                                                                            
              <Text text="{catalog>/kpi/active}" class="catKpiNumber catKpiNumber--green" />                                                                                                                                                                   
              <core:Icon src="sap-icon://sys-enter-2" color="#107e3e" size="0.9rem" class="catKpiIconSpacer" />                                                                                                                                                
              <Text text="Active" class="catKpiLabel catKpiLabel--green" />                                                                                                                                                                                    
            </VBox>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            <VBox alignItems="Center" justifyContent="Center" class="catKpiCard catKpiCard--grey">                                                                                                                                                             
              <Text text="{catalog>/kpi/inactive}" class="catKpiNumber catKpiNumber--grey" />                                                                                                                                                                  
              <core:Icon src="sap-icon://sys-cancel" color="#6a6d70" size="0.9rem" class="catKpiIconSpacer" />                                                                                                                                                 
              <Text text="Inactive" class="catKpiLabel catKpiLabel--grey" />                                                                                                                                                                                   
            </VBox>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
          </HBox>                                                                                                                                                                                                                                              
        </HBox>                                                                                                                                                                                                                                                
      </f:DynamicPageHeader>                                                                                                                                                                                                                                   
    </f:header>                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
    <!-- ─── Content ─── -->                                                                                                                                                                                                                                   
    <f:content>                                                                                                                                                                                                                                                
      <VBox class="sapUiMediumMarginBegin sapUiMediumMarginEnd sapUiSmallMarginTop sapUiMediumMarginBottom">                                                                                                                                                   
                                                                                                                                                                                                                                                               
        <!-- Toolbar -->                                                                                                                                                                                                                                       
        <Toolbar design="Transparent" class="sapUiSmallMarginBottom">                                                                                                                                                                                          
          <Title text="All Configurations" level="H4" />                                                                                                                                                                                                       
          <ToolbarSpacer />                                                                                                                                                                                                                                    
          <SearchField                                                                                                                                                                                                                                         
            width="22rem"                                                                                                                                                                                                                                      
            placeholder="Search by name, module, CDS, description..."                                                                                                                                                                                          
            search=".onSearch"                                                                                                                                                                                                                                 
            liveChange=".onSearch" />                                                                                                                                                                                                                          
          <SegmentedButton selectionChange=".onModuleFilterChange" class="sapUiSmallMarginBegin">                                                                                                                                                              
            <items>                                                                                                                                                                                                                                            
              <SegmentedButtonItem text="All" key="ALL" />                                                                                                                                                                                                     
              <SegmentedButtonItem text="MM"  key="MM"  />                                                                                                                                                                                                     
              <SegmentedButtonItem text="SD"  key="SD"  />                                                                                                                                                                                                     
              <SegmentedButtonItem text="FI"  key="FI"  />                                                                                                                                                                                                     
            </items>                                                                                                                                                                                                                                           
          </SegmentedButton>                                                                                                                                                                                                                                   
        </Toolbar>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        <!-- Catalog Table -->                                                                                                                                                                                                                                 
        <Table                                                                                                                                                                                                                                                 
          id="catalogTable"                                                                                                                                                                                                                                    
          items="{catalog>/catalogs}"                                                                                                                                                                                                                          
          noDataText="No configurations found"                                                                                                                                                                                                                 
          growing="true"                                                                                                                                                                                                                                       
          growingThreshold="20"                                                                                                                                                                                                                                
          busyIndicatorDelay="0"                                                                                                                                                                                                                               
          busy="{catalog>/loading}"                                                                                                                                                                                                                            
          class="catTable">                                                                                                                                                                                                                                    
          <columns>                                                                                                                                                                                                                                            
            <Column width="10%"><Text text="Module" /></Column>                                                                                                                                                                                                
            <Column width="25%"><Text text="Configuration Name" /></Column>                                                                                                                                                                                    
            <Column width="12%"><Text text="Type" /></Column>                                                                                                                                                                                                  
            <Column width="25%"><Text text="Description" /></Column>                                                                                                                                                                                           
            <Column width="18%"><Text text="Target CDS" /></Column>                                                                                                                                                                                            
            <Column width="10%" hAlign="Center"><Text text="Status" /></Column>                                                                                                                                                                                
          </columns>                                                                                                                                                                                                                                           
          <items>                                                                                                                                                                                                                                              
            <ColumnListItem type="Navigation" press=".onRowPress">                                                                                                                                                                                             
              <cells>                                                                                                                                                                                                                                          
                <!-- Module -->                                                                                                                                                                                                                                
                <ObjectStatus                                                                                                                                                                                                                                  
                  text="{catalog>ModuleId}"                                                                                                                                                                                                                    
                  state="{catalog>ModuleState}"                                                                                                                                                                                                                
                  inverted="true" />                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
                <!-- Name + ID -->                                                                                                                                                                                                                             
                <VBox>                                                                                                                                                                                                                                         
                  <Text text="{catalog>ConfName}" maxLines="1" class="catRowTitle" />                                                                                                                                                                          
                  <Text text="{catalog>ConfId}" class="catRowSubtitle" />                                                                                                                                                                                      
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Type -->                                                                                                                                                                                                                                  
                <Text text="{catalog>ConfType}" />                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                <!-- Description -->                                                                                                                                                                                                                           
                <Text text="{catalog>Description}" maxLines="2" wrapping="true" />                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                <!-- Target CDS -->                                                                                                                                                                                                                            
                <Text text="{catalog>TargetCds}" class="catCdsText" />                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
                <!-- Status -->                                                                                                                                                                                                                                
                <ObjectStatus                                                                                                                                                                                                                                  
                  text="{catalog>StatusText}"                                                                                                                                                                                                                  
                  state="{catalog>StatusState}"                                                                                                                                                                                                                
                  icon="{= ${catalog>IsActive} ? 'sap-icon://sys-enter-2' : 'sap-icon://sys-cancel'}" />                                                                                                                                                       
              </cells>                                                                                                                                                                                                                                         
            </ColumnListItem>                                                                                                                                                                                                                                  
          </items>                                                                                                                                                                                                                                             
        </Table>                                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
      </VBox>                                                                                                                                                                                                                                                  
    </f:content>                                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
  </f:DynamicPage>                                                                                                                                                                                                                                             
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               